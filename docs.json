{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Documentation",
  "colors": {
    "primary": "#EF4444",
    "light": "#F87171",
    "dark": "#DC2626"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Scripts",
        "pages": [
          "store",
          "general-faqs",
          "escrow-errors",
          {
            "group": "CDX Store",
            "icon": "store",
            "pages": [
              "in-game-store/preview",
              "in-game-store/installation",
              "in-game-store/changelog",
              "in-game-store/integrations",
              {
                "group": "Exports",
                "pages": [
                  "client",
                  "server"
                ],
                "icon": "file-export"
              },
              {
                "group": "Events",
                "pages": [
                  "client-1",
                  "server-1"
                ],
                "icon": "code"
              }
            ],
            "expanded": true
          }
        ]
      },
      {
        "tab": "Store",
        "href": "https://cdx-foundation.dev"
      },
      {
        "tab": "Github",
        "href": "https://github.com/cdx-foundation"
      },
      {
        "tab": "Discord",
        "href": "https://discord.gg/uqDRPkvmdh"
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@example.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.example.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/",
      "github": "https://github.com/",
      "linkedin": "https://linkedin.com/"
    }
  },
  "appearance": {
    "default": "dark"
  },
  "background": {
    "color": {
      "dark": "#0A0000"
    }
  }
}
